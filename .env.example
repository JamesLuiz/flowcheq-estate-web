# =============================================================================
# Flowcheq Estate — Web frontend (.env.example)
# =============================================================================
# Vite only exposes variables prefixed with VITE_
#
# Local development — copy to `.env.local` (recommended by Vite):
#   cp .env.example .env.local
#
# Production build — set in your host (Vercel, Docker build-arg, etc.)
# Docker example:
#   docker build --build-arg VITE_API_URL=https://api.estate.flowcheq.com .
#
# Never commit `.env` or `.env.local` — they are gitignored.
# =============================================================================

# --- Required ---

# Backend API base URL (no trailing slash)
VITE_API_URL=https://api.estate.flowcheq.com

# Public base URL of this web app (used for absolute links/share metadata where needed)
VITE_WEB_URL=https://estate.flowcheq.com

# Google Maps JavaScript API key (Maps UI + geocoding on listing forms)
# Enable: Maps JavaScript API, Places API, Geocoding API
VITE_GOOGLE_MAPS_API_KEY=

# --- Realtime messaging (Pusher) — optional; falls back to polling if empty ---

VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=mt1

# --- Contact form (EmailJS) — optional; /contact page ---

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# --- Agent app download page (/agents/app) — optional ---

# Direct Android APK hosted on this site (after EAS build)
VITE_ANDROID_APK_URL=https://estate.flowcheq.com/downloads/flowcheq-estate-android.apk

# Google Play / App Store links (when you publish to stores)
VITE_ANDROID_PLAY_URL=https://play.google.com/store/apps/details?id=com.flowcheq.estate
VITE_IOS_APP_STORE_URL=https://apps.apple.com/app/flowcheq-estate/id000000000

# --- PWA install behavior ---
# Set to false to hide install prompt UI while keeping manifest/service worker active
# VITE_PWA_INSTALL_PROMPT=true

# --- Development / staging only ---

# Allow web file-picker for listing photos instead of mobile-only capture
# VITE_ALLOW_WEB_LISTING_PHOTOS=true

# Mapbox (legacy; only if you still use Mapbox components)
# VITE_MAPBOX_ACCESS_TOKEN=
